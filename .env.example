# Your domain. DNS must point both of these at the server IP:
#   A   abc.com     -> SERVER_IP
#   A   *.abc.com   -> SERVER_IP
DOMAIN=abc.com

# Email for Let's Encrypt TLS certificates
ACME_EMAIL=you@example.com

# Your Claude Pro/Max login token. Generate it with:
#   npx @anthropic-ai/claude-code setup-token
CLAUDE_CODE_OAUTH_TOKEN=

# Idea source = Reddit via the public pullpush.io API. No Reddit account or app
# needed. Just optionally customize the user-agent string.
REDDIT_USER_AGENT=AppFarm/1.0 (self-hosted)

# Only consider Reddit posts from the last N days (keeps picks reasonably fresh;
# 730 = ~2 years). Lower it for more recent-only ideas.
IDEA_MAX_AGE_DAYS=730

# --- Lifecycle / pruning ---
APP_LIFETIME_DAYS=30
MIN_VISITS_TO_SURVIVE=50
MAX_LIVE_APPS=40
# Visits an app needs to earn the 👑 winner badge on the dashboard
WINNER_VISITS=100

# --- Optional ---
# Extra communities (comma-separated subreddit names, without "r/")
EXTRA_SUBREDDITS=

# Override the model Claude Code uses (blank = your Claude Code default)
CLAUDE_MODEL=

# Set to 1 to skip Claude and deploy the bare template (test without using credits)
APPFARM_FAKE_BUILD=0

# Set to 0 to pause the daily build cycle (no new app gets generated). Existing
# apps stay live and the dashboard keeps working. Handy while filming/demoing.
APPFARM_BUILDS_ENABLED=1

# Set to 0 to serve plain HTTP instead of HTTPS (local testing only)
APPFARM_ENABLE_TLS=1
